#include <stdio.h>

struct student {
    int id;
    char name[50];
    float marks;
};

int main() {
    struct student s[100];
    int n, i, choice, search_id, found = 0;

    printf("Enter number of students: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("\nEnter details for student %d\n", i + 1);
        printf("ID: ");
        scanf("%d", &s[i].id);
        printf("Name: ");
        scanf("%s", s[i].name);
        printf("Marks: ");
        scanf("%f", &s[i].marks);
    }

    while(1) {
        printf("\n1. Display\n2. Search by ID\n3. Exit\nEnter choice: ");
        scanf("%d", &choice);

        if(choice == 1) {
            for(i = 0; i < n; i++) {
                printf("\nID: %d\nName: %s\nMarks: %.2f\n", s[i].id, s[i].name, s[i].marks);
            }
        }
        else if(choice == 2) {
            printf("Enter ID to search: ");
            scanf("%d", &search_id);

            found = 0;
            for(i = 0; i < n; i++) {
                if(s[i].id == search_id) {
                    printf("\nRecord Found!\n");
                    printf("ID: %d\nName: %s\nMarks: %.2f\n", s[i].id, s[i].name, s[i].marks);
                    found = 1;
                    break;
                }
            }

            if(found == 0) {
                printf("Record not found!\n");
            }
        }
        else if(choice == 3) {
            break;
        }
        else {
            printf("Invalid choice!\n");
        }
    }

    return 0;
}
