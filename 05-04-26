#include <stdio.h>
#include <stdlib.h>

struct student {
    int id;
    char name[50];
    float marks;
};

int main() {
    FILE *fp;
    struct student s;
    int choice, searchId;

    while (1) {
        printf("\n1.Add\n2.Display\n3.Search\n4.Exit\n");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                fp = fopen("data.txt", "a");
                printf("Enter ID Name Marks:\n");
                scanf("%d %s %f", &s.id, s.name, &s.marks);
                fwrite(&s, sizeof(s), 1, fp);
                fclose(fp);
                break;

            case 2:
                fp = fopen("data.txt", "r");
                while (fread(&s, sizeof(s), 1, fp)) {
                    printf("%d %s %.2f\n", s.id, s.name, s.marks);
                }
                fclose(fp);
                break;

            case 3:
                fp = fopen("data.txt", "r");
                printf("Enter ID:\n");
                scanf("%d", &searchId);
                while (fread(&s, sizeof(s), 1, fp)) {
                    if (s.id == searchId) {
                        printf("Found: %d %s %.2f\n", s.id, s.name, s.marks);
                        break;
                    }
                }
                fclose(fp);
                break;

            case 4:
                exit(0);

            default:
                printf("Invalid choice\n");
        }
    }
}
