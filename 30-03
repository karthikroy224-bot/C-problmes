#include <stdio.h>
#include <string.h>

struct student {
    int id;
    char name[50];
    float marks;
};

int main() {
    struct student s[100];
    int n = 0, choice, i, search_id, found;

    while(1) {
        printf("\n1.Add\n2.Display\n3.Search\n4.Exit\n");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Enter ID Name Marks:\n");
                scanf("%d %s %f", &s[n].id, s[n].name, &s[n].marks);
                n++;
                break;

            case 2:
                for(i = 0; i < n; i++) {
                    printf("%d %s %.2f\n", s[i].id, s[i].name, s[i].marks);
                }
                break;

            case 3:
                printf("Enter ID to search:\n");
                scanf("%d", &search_id);
                found = 0;

                for(i = 0; i < n; i++) {
                    if(s[i].id == search_id) {
                        printf("%d %s %.2f\n", s[i].id, s[i].name, s[i].marks);
                        found = 1;
                        break;
                    }
                }

                if(!found) {
                    printf("Not found\n");
                }
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice\n");
        }
    }
}
