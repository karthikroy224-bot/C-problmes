#include<stdio.h>
int main(){

    int fuel;
    int n,i=0,sum=0;
    int fuel_trip,count=0,remaing_fuel=0;

    scanf("%d",&fuel);
    scanf("%d",&n);
    
    while(i<n){
        scanf("%d",&fuel_trip);
        sum+=fuel_trip;

        if(sum<=fuel){
            count++;
            remaing_fuel=fuel-sum;
        }

        i++;
    }

    printf("Remaining fuel : %d\n",remaing_fuel);
    printf("Completed trips : %d\n",count);
    

    return 0;
}
