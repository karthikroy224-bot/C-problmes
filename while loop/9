#include<stdio.h>
int main(){
    int n;
    int hours_day,sum=0,count=0;
    scanf("%d",&n);
    int i=0;
    while(i<n){
        scanf("%d",&hours_day);
        sum+=hours_day;

        if(hours_day>4){
            count++;
        }
        i++;
    }

    printf("Total Overtime : %d\n",sum);
    printf("Burn outs : %d\n",count);
    return 0;
}
