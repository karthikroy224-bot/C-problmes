#include <stdio.h>

float average(int arr[], int n) {
    int sum = 0;
    for(int i = 0; i < n; i++) {
        sum += arr[i];
    }
    return (float)sum / n;
}

int highest(int arr[], int n) {
    int max = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] > max) {
            max = arr[i];
        }
    }
    return max;
}

int lowest(int arr[], int n) {
    int min = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] < min) {
            min = arr[i];
        }
    }
    return min;
}

int main() {
    int n;
    printf("Enter number of students: ");
    scanf("%d", &n);

    int marks[n];

    printf("Enter marks:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &marks[i]);
    }

    printf("Average = %.2f\n", average(marks, n));
    printf("Highest = %d\n", highest(marks, n));
    printf("Lowest = %d\n", lowest(marks, n));

    return 0;
}
