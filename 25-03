#include<stdio.h>

struct student{
    int id;
    char name[50];
    float marks;
};

void display(struct student s[], int n){
    int i;
    for(i=0;i<n;i++){
        printf("ID: %d\n",s[i].id);
        printf("Name: %s\n",s[i].name);
        printf("Marks: %.2f\n",s[i].marks);
        printf("\n");
    }
}

int main(){
    int n,i;
    scanf("%d",&n);

    struct student s[n];

    for(i=0;i<n;i++){
        scanf("%d",&s[i].id);
        scanf("%s",s[i].name);
        scanf("%f",&s[i].marks);
    }

    display(s,n);

    return 0;
}
