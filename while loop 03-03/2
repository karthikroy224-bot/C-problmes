#include<stdio.h>
int main(){

    int capacity;
    int n,i=0,count=0,sum=0;
    int ppl;

    scanf("%d",&capacity);
    scanf("%d",&n);

    while(i<n){
        scanf("%d",&ppl);
        sum+=ppl;

        if(sum>(capacity*90)/100){
            count++;
        }
        
        i++;
    }

    printf("Final Occupied Beds :%d\n",sum);
    printf("Critical hours :%d",count);
    
    return 0;
}
